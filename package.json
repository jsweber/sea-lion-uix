    "build": "pnpm run build:mjs && pnpm run build:theme",
    "build:mjs": "node scripts/build.mjs",
    "build:theme": "cd packages/react/theme && pnpm run build:css",
    "dev": "pnpm run build:theme && npm run storybook",
    "clean": "rm -v",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "publish-stable": "pnpm run build && pnpm changeset && pnpm changeset publish",
    "publish-fix": "pnpm changeset && pnpm changeset publish",
    "preinstall": "npx only-allow pnpm"
  },

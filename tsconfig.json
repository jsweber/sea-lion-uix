            ],
            "@sea-lion/react-table": [
                "./packages/react/table/src"
            ],
            "@sea-lion/react-text": [
                "./packages/react/text/src"
            ],
            "@sea-lion/react-text-area": [
                "./packages/react/text-area/src"
            ],
            "@sea-lion/react-tooltip": [
                "./packages/react/tooltip/src"
            ],
            "@sea-lion/react-theme": [
                "./packages/react/theme/src"
            ],
            "@sea-lion/react-theme-panel": [
